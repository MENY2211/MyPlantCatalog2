<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FAFAF5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Imagen circular con borde dorado -->
        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="14dp"
            app:cardCornerRadius="36dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#C8A84B">

            <androidx.cardview.widget.CardView
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:layout_margin="3dp"
                app:cardCornerRadius="33dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgPlanta"
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    android:scaleType="centerCrop" />

            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>

        <!-- Textos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreComun"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1B4332"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvNombreCientifico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:textStyle="italic"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvUsos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#374151"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVer"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="Ver detalle"
                android:textColor="#1B4332"
                android:textSize="12sp"
                app:chipBackgroundColor="#A8D5B5"
                app:chipCornerRadius="8dp"
                app:chipStrokeColor="#1B4332"
                app:chipStrokeWidth="1dp"/>

        </LinearLayout>

        <!-- Estrella favorito -->
        <ImageButton
            android:id="@+id/btnFavorito"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Favorito"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="6dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>