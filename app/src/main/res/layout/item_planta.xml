<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/blanco">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/img_planta"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:contentDescription="Foto de la planta" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_nombre_comun"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/verde_dark"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tv_nombre_cientifico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="@color/texto_suave"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_usos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/texto_suave"
                android:maxLines="2"
                android:ellipsize="end" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_ver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ver detalle"
                app:chipBackgroundColor="@color/verde_light"
                app:chipStrokeColor="@color/verde_primary"
                app:chipStrokeWidth="1dp"
                android:textColor="@color/verde_primary" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>