<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/md_outline_variant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/md_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Imagen circular -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="38dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/md_outline_variant"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/md_surface_variant">

            <ImageView
                android:id="@+id/imgPlanta"
                android:layout_width="76dp"
                android:layout_height="76dp"
                android:scaleType="centerCrop"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Textos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreComun"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface"
                android:layout_marginBottom="3dp"/>

            <TextView
                android:id="@+id/tvNombreCientifico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/md_on_surface_variant"
                android:textStyle="italic"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvUsos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/md_on_surface_variant"
                android:layout_marginBottom="10dp"/>

            <!-- Botón píldora MD3 tonal -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/chipVer"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Ver detalle"
                android:textSize="12sp"
                android:textColor="@color/md_on_primary_container"
                app:backgroundTint="@color/md_primary_container"
                app:cornerRadius="100dp"
                app:iconPadding="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                style="@style/Widget.Material3.Button.TonalButton"/>

        </LinearLayout>

        <!-- Estrella favorito -->
        <ImageButton
            android:id="@+id/btnFavorito"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Favorito"
            android:layout_marginStart="8dp"
            android:layout_gravity="top"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>