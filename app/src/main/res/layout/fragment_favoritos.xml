<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_crema"
    android:paddingTop="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mis Favoritos"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/verde_oscuro"
        android:paddingStart="16dp"
        android:layout_marginBottom="10dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerFavoritos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

    <TextView
        android:id="@+id/tvFavoritosVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⭐ Aún no tienes favoritos.\nPresiona la estrella en cualquier planta para guardarla aquí."
        android:textColor="#9E9E9E"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="64dp"
        android:textSize="15sp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"/>

</LinearLayout>