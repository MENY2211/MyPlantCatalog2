<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mis Plantas"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:layout_marginBottom="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerMisPlantas"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tvMisPlantasVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌱 Aún no tienes notas.\nAgrega una nota a cualquier planta desde su detalle."
        android:textColor="#888"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="64dp"
        android:textSize="15sp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAgregarNota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:contentDescription="Agregar nota"
        android:src="@android:drawable/ic_input_add"
        android:backgroundTint="#388E3C"/>

</LinearLayout>