<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explorar Plantas"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface"
            android:layout_marginBottom="16dp"/>

        <!-- Barra de búsqueda estilo MD3 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            app:cardCornerRadius="100dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/md_outline_variant"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/md_surface_variant"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="16sp"
                    android:layout_marginEnd="10dp"/>

                <EditText
                    android:id="@+id/etBuscar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Buscar por nombre o síntoma..."
                    android:inputType="text"
                    android:background="@null"
                    android:textColorHint="@color/md_on_surface_variant"
                    android:textColor="@color/md_on_surface"
                    android:textSize="14sp"
                    android:singleLine="true"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerExplorar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"/>

    <TextView
        android:id="@+id/tvSinResultados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌿 No se encontraron plantas."
        android:textColor="@color/md_on_surface_variant"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="48dp"
        android:textSize="15sp"/>

</LinearLayout>