<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/md_outline_variant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/md_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagen de planta asociada -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/imgNotaPlanta"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/planta_hierba_santa"/>

            <!-- Chip de categoría -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:text="GENERAL"
                android:textSize="10sp"
                android:textColor="@color/md_on_surface"
                app:chipBackgroundColor="@android:color/white"
                app:chipCornerRadius="6dp"
                app:chipMinHeight="28dp"/>

        </FrameLayout>

        <!-- Contenido -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Título y fecha -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvNotaTitulo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_primary"/>

                <TextView
                    android:id="@+id/tvNotaFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/md_on_surface_variant"/>

            </LinearLayout>

            <!-- Vista previa del texto -->
            <TextView
                android:id="@+id/tvNotaPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/md_on_surface_variant"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="12dp"/>

            <!-- Pie: puntos indicadores + leer más -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Dots decorativos -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_active"
                    android:layout_marginEnd="4dp"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_inactive"
                    android:layout_marginEnd="4dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvLeerMas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Leer nota completa →"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>